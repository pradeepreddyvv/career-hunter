# Career Hunter Environment Configuration
# Copy this to .env.local and fill in your values

# =============================================================================
# AI PROVIDER (Required — pick one)
# =============================================================================

# Google Gemini (recommended, free tier: 15 req/min)
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OR OpenAI / any OpenAI-compatible API
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# =============================================================================
# AUTH (Required for multi-user, optional for local dev)
# =============================================================================

# Secret for signing JWT tokens (change in production!)
JWT_SECRET=career-hunter-change-this-secret

# Google OAuth (optional — for "Sign in with Google")
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# =============================================================================
# SPEECH (Optional — enhances interview experience)
# =============================================================================

# Speechmatics (better STT quality, $0.50/hr)
# Get key: https://portal.speechmatics.com
# SPEECHMATICS_API_KEY=

# =============================================================================
# JOB DISCOVERY (Optional — scraping mode)
# =============================================================================

# Apify (LinkedIn scraping, $5/mo)
# APIFY_TOKEN=

# JSearch / RapidAPI (200 req/month free)
# JSEARCH_API_KEY=

# =============================================================================
# NOTIFICATIONS (Optional)
# =============================================================================

# Resend (email alerts, 3,000/month free)
# Get key: https://resend.com
# RESEND_API_KEY=
# NOTIFICATION_EMAIL=your@email.com

# =============================================================================
# n8n SCRAPING (Optional — for non-API job portals)
# =============================================================================

# n8n instance URL (only needed if running n8n for Workday/LinkedIn scraping)
# N8N_URL=http://localhost:5678
# N8N_USER=admin
# N8N_PASSWORD=changeme

# =============================================================================
# DATABASE (Optional — defaults to SQLite)
# =============================================================================

# Uncomment to use PostgreSQL instead of SQLite
# DATABASE_URL=postgresql://user:password@localhost:5432/career-hunter

# SQLite path (default: ./data/career-hunter.db)
# SQLITE_PATH=./data/career-hunter.db
